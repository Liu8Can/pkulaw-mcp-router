{
  "name": "pkulaw-mcp-router",
  "version": "0.2.2",
  "description": "Merge multiple PKULAW MCP sub-services into one local MCP server.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pkulaw-mcp-router": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "catalog",
    "LICENSE",
    "config.example.toml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "discover": "tsx src/index.ts discover",
    "inspect": "tsx src/index.ts inspect",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pkulaw",
    "router",
    "aggregator",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Liu8Can/pkulaw-mcp-router.git"
  },
  "bugs": {
    "url": "https://github.com/Liu8Can/pkulaw-mcp-router/issues"
  },
  "homepage": "https://github.com/Liu8Can/pkulaw-mcp-router#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
